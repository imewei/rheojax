# Sphinx build outputs
build/
_build/

# Sphinx auto-generated files
source/_autosummary/
source/api/generated/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Archive files (preserved in Git but not built)
# Uncomment the line below if you want to exclude archive from Git
# .archive/

# Temporary files
*.tmp
*.swp
*~
.DS_Store

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
# Graphify semantic cache (ephemeral build artifacts)
graphify-out/cache/

# Claude session scratch files in docs
docs/.claude-progress.md

# Graphify internal working state files
graphify-out/.graphify_*.json
graphify-out/.graphify_*.txt
graphify-out/.obsidian/
graphify-out/_COMMUNITY_*.md
